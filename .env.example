# === Database ===
# Docker Compose overrides this automatically. Only needed for local (non-Docker) dev.
DATABASE_URL=postgresql://reachout:reachout@localhost:5432/reachout

# === Redis (optional — app works without it, caching disabled) ===
# Docker Compose overrides this automatically.
REDIS_URL=redis://localhost:6379/0

# === Supabase (required — handles authentication) ===
# Create a free project at https://supabase.com and copy these values.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SECRET_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret
# === TikTok Scraping ===
# Your TikTok handle (filtered from search results to avoid discovering yourself)
MY_HANDLE=your_tiktok_handle

# === AI Outreach (Claude API) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Frontend (passed as build args to Vite in Docker) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
